APP_NAME=Invoice Processing System
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Option 1: set full URL
# MYSQL_URL=mysql://root:password@localhost:3306/invoices
MYSQL_URL=

# Option 2: set discrete fields
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=invoices
MYSQL_MIN_POOL_SIZE=1
MYSQL_MAX_POOL_SIZE=10

SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_FORMATS=png,jpg,jpeg,pdf

MAX_FILE_SIZE=10485760
UPLOAD_DIR=data/uploads
PROCESSING_TIMEOUT=300
BATCH_SIZE=50

LOG_LEVEL=INFO
LOG_FILE=logs/app.log
